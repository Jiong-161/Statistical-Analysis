<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:andrid="http://schemas.android.com/apk/distribution"
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.accounts"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="28"
        android:targetSdkVersion="34" />

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <permission
        android:name="com.example.accounts.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.accounts.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="com.example.accounts.UniteApp"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme" >
        <activity
            android:name="com.example.accounts.HistoryActivity"
            android:exported="false" />
        <activity
            android:name="com.example.accounts.ChartActivity"
            android:exported="false" />
        <activity
            android:name="com.example.accounts.MainActivity"
            android:exported="false" />
        <activity
            android:name="com.example.accounts.SearchActivity"
            android:exported="false" /> <!-- <activity -->
        <!-- android:name="." -->
        <!-- android:exported="false" /> -->
        <activity
            android:name="com.example.accounts.RecordActivity"
            android:exported="false" />
        <activity
            android:name="com.example.accounts.utils.login"
            android:theme="@style/AppTheme.WithActionBar" />
        <activity
            android:name="com.example.accounts.SettingsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.accounts.AboutActivity"
            android:exported="false" />
        <activity
            android:name="com.example.accounts.userActivity"
            android:exported="true"
            android:theme="@style/AppTheme.WithActionBar" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.example.accounts.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>