<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/colorPrimary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_sm">

        <ImageView
            android:id="@+id/about_iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/iv_back"
            android:tint="@color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="关于"
            android:textColor="@color/white"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- 内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Logo -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginTop="24dp" />

            <!-- 应用名称 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="统计分析记账管理系统"
                android:textColor="#333333"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- 版本号 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="版本号: 2.0"
                android:textColor="#999999"
                android:textSize="14sp" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:background="#E0E0E0" />

            <!-- 功能介绍 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="应用介绍"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="4dp"
                    android:text="个人记账管理系统是一款便捷的移动记账应用，帮助用户轻松记录和管理日常收支，养成良好的理财习惯。"
                    android:textColor="#666666"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- 主要功能 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="主要功能"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:padding="16dp"
                    android:background="#FFFFFF"
                    android:elevation="1dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• 快速记账：支持收入、支出记录"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• 数据统计：收支统计、图表分析"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• 智能搜索：快速查找历史记录"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• 预算管理：设置月度预算目标"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• 数据备份：本地数据备份与恢复"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 版权信息 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Copyright © 2026 统计分析记账管理系统"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
