<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_md"
    android:layout_marginVertical="@dimen/spacing_xs"
    android:background="@drawable/bg_card_default"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_md">

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/search"
        android:tint="@color/text_hint"/>

    <TextView
        android:id="@+id/tv_history_keyword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_body"/>

    <ImageView
        android:id="@+id/iv_history_delete"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="@dimen/spacing_xs"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@color/text_hint"
        android:contentDescription="删除"/>
</LinearLayout>
