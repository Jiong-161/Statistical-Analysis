<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppButtonPrimary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_primary_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
    </style>

    <style name="AppButtonIcon" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@drawable/bg_icon_button</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:padding">10dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="AppStatLabel">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="AppStatValue">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="dialogmoreStyle">
        <item name="android:background">@drawable/bg_more_menu_item</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
