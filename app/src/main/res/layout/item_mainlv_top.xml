<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background"
    android:paddingBottom="@dimen/spacing_sm">

    <!-- 月度收支统计卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_md"
        android:background="@drawable/bg_card_default"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本月概览"
                android:textSize="@dimen/text_subtitle"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <ImageView
                android:id="@+id/item_mainlv_top_iv_hide"
                android:layout_width="@dimen/icon_size_sm"
                android:layout_height="@dimen/icon_size_sm"
                android:layout_alignParentEnd="true"
                android:padding="@dimen/spacing_xs"
                android:src="@drawable/ih_show"
                android:contentDescription="隐藏金额"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/AppStatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/month_out"/>

                <TextView
                    android:id="@+id/item_mainlv_top_tv_out"
                    style="@style/AppStatValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="￥0"
                    android:textColor="@color/outcome"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    style="@style/AppStatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/month_in"/>

                <TextView
                    android:id="@+id/item_mainlv_top_tv_in"
                    style="@style/AppStatValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="￥0"
                    android:textColor="@color/income"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    style="@style/AppStatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/budget"/>

                <TextView
                    android:id="@+id/item_mainlv_top_tv_budget"
                    style="@style/AppStatValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="￥0"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 今日收支摘要 -->
    <TextView
        android:id="@+id/item_mainlv_top_tv_day"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_header_summary"
        android:gravity="center"
        android:paddingVertical="@dimen/spacing_md"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:text="今日支出 ￥0  收入 ￥0"
        android:textColor="@color/white"
        android:textSize="@dimen/text_body"
        android:textStyle="bold"/>

    <!-- 图表入口提示 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_sm"
        android:drawableStart="@drawable/ih_biaoge"
        android:drawablePadding="@dimen/spacing_sm"
        android:gravity="center_vertical"
        android:text="@string/see_excel"
        android:textColor="@color/colorPrimary"
        android:textSize="@dimen/text_caption"/>

</LinearLayout>
